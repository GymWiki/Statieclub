# Supabase project URL en publieke (anon) key — client-side te gebruiken
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — alleen server-side (API routes), nooit naar de client sturen
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe secret key (test- of live-key uit je Stripe-dashboard) —
# alleen server-side gebruikt, voor Stripe Connect (zie lib/stripe.ts)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Signing secret van de webhook endpoint in je Stripe-dashboard
# (Developers → Webhooks) — nodig om /api/stripe/webhook-events te
# verifiëren. Begint met whsec_.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publiek bereikbare basis-URL van deze app (geen trailing slash) —
# nodig voor Stripe's success/cancel/return-URL's. In productie je
# eigen domein; lokaal moet dit publiek bereikbaar zijn (bijv. via
# `stripe listen --forward-to localhost:3000/api/stripe/webhook`) wil
# Stripe's webhook je kunnen bereiken.
NEXT_PUBLIC_SITE_URL=https://jouw-domein.nl

# Geheim dat de dagelijkse cron-job (/api/cron/close-acties) verwacht
# in de 'Authorization: Bearer <CRON_SECRET>'-header — zet dezelfde
# waarde in de cron-configuratie (Vercel Cron Jobs sturen dit
# automatisch mee zodra je deze env var instelt).
CRON_SECRET=kies-een-lang-willekeurig-geheim
