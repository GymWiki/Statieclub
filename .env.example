# Supabase project URL en publieke (anon) key — client-side te gebruiken
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — alleen server-side (API routes), nooit naar de client sturen
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mollie API-key (test- of live-key uit je Mollie-dashboard) — alleen
# server-side gebruikt, voor SEPA Automatische Incasso (zie lib/mollie.ts)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publiek bereikbare basis-URL van deze app (geen trailing slash) —
# nodig voor Mollie's redirectUrl/webhookUrl. In productie je eigen
# domein; lokaal moet dit publiek bereikbaar zijn (bijv. via ngrok) wil
# Mollie's webhook je kunnen bereiken.
NEXT_PUBLIC_SITE_URL=https://jouw-domein.nl

# Geheim dat de maandelijkse cron-job (/api/cron/monthly-billing)
# verwacht in de 'Authorization: Bearer <CRON_SECRET>'-header — zet
# dezelfde waarde in de cron-configuratie (bijv. Vercel Cron Jobs, die
# dit automatisch meesturen als je deze env var instelt).
CRON_SECRET=kies-een-lang-willekeurig-geheim
